/* Libcxx.edl - EDL sample for trusted C++ library. */

enclave {
    
    /* 
     * A subset of the C++03 standard is supported.
     */

    trusted {

		/* BINARY OP */
		public void ecall_binary_double_multiplication_executor([user_check]void* l_encrypted, [user_check]void** l_decrypted, [user_check]void* r_encrypted, [user_check]void** r_decrypted, [user_check]void** result_decrypted, [user_check]void* l_sel, [user_check]void* r_sel, int count);

		/* AGGREGATE */
		public void ecall_aggregate_unary_double_update_executor([user_check]void* encrypted, [user_check]void** decrypted, [user_check]void* state, int count);

        /* ZONE MAP */
		public void ecall_init_minmax(void);
		public void ecall_get_minmax(void);
		public void ecall_set_minmax(void);
    };
};
